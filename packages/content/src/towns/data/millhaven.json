    },
    {
      "name": "The Millhaven Forge",
      "type": "blacksmith",
      "description": "Best ironwork in three towns. Weapons, tools, horseshoes. Never closes before dark.",
      "npcInstances": ["torval_grimm", "pip_apprentice"]
    },
    {
      "name": "Green Gate Bakery",
      "type": "bakery",
