    },
    {
      "name": "The Tipsy Gnome",
      "type": "tavern",
      "description": "A squat, round-roofed tavern on lower Mill Road that leans slightly to the left. Cozy, unpretentious, and fiercely loyal to its regulars.",
      "locationFile": "tipsy_gnome",
      "npcInstances": ["mira_barrelbottom", "lell_sparrow", "bob_the_porous", "amethyst_the_wildcard", "fen_colby"]
    },
