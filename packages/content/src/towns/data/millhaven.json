{
  "id": "millhaven",
  "name": "Millhaven",
  "type": "market_town",
  "population": 1200,
  "description": "A prosperous market town at the crossroads of two regional trade routes. Millhaven smells of bread, horse, and river mud. It is not remarkable — and that is exactly why people stay. The cobblestones are uneven, the inn is loud on weekends, the guards are underpaid but loyal, and everyone knows everyone. Strangers are noticed within an hour.",
  "location": {
    "region": "The Vale",
    "terrain": "river valley",
    "nearestLandmarks": ["Stoneback River (1 mile east)", "King's Road (runs through center)", "Darkwood Forest (3 miles north)"],
    "climate": "temperate"
  },
  "atmosphere": {
    "defaultTone": "ordinary",
    "tags": ["safe", "gossipy", "mercantile", "slightly suspicious of outsiders"],
    "sounds": ["market chatter", "hammer on anvil", "river birds", "children shouting", "wagon wheels on cobblestone"],
    "smells": ["fresh bread", "horse and hay", "river mud", "wood smoke", "tanning leather"]
  },
  "notableLocations": [
    {
      "name": "Bottoms Up",
      "type": "inn_and_tavern",
